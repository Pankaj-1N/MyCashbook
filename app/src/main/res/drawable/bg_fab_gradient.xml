<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow/Glow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="40dp"
                android:startColor="#4D00B0FF"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- Main Button -->
    <item android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="45"
                android:endColor="#00B0FF"
                android:startColor="#0091EA"
                android:type="linear" />
            <stroke android:width="1.5dp" android:color="#80FFFFFF" />
        </shape>
    </item>
</layer-list>
