<?xml version="1.0" encoding="utf-8"?>
<!-- Light theme background for main activity screens -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Light Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/light_background" />
        </shape>
    </item>

    <!-- Subtle top gradient for depth -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#08000000"
                android:endColor="#00000000"
                android:type="linear" />
        </shape>
    </item>

    <!-- Bottom right accent - subtle blue hint -->
    <item android:bottom="-50dp" android:right="-50dp">
        <shape android:shape="oval">
            <size android:width="200dp" android:height="200dp" />
            <gradient
                android:centerX="50%"
                android:centerY="50%"
                android:gradientRadius="100dp"
                android:startColor="#082196F3"
                android:endColor="#00FFFFFF"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
