<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base Application Theme (LIGHT) -->
    <style name="Base.Theme.MyCashBook" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/light_accent</item>
        <item name="colorPrimaryDark">@color/light_accent_dark</item>
        <item name="colorAccent">@color/light_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Background Colors -->
        <item name="android:colorBackground">@color/light_background</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorSurfaceVariant">@color/light_card</item>
        <item name="colorOnSurface">@color/light_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/light_text_secondary</item>
        
        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/light_text_primary</item>
        <item name="android:textColorSecondary">@color/light_text_secondary</item>
        <item name="android:textColorHint">@color/light_text_hint</item>
        
        <!-- Status Bar (Transparent - Let System Handle) -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        
        <!-- Card Colors -->
        <item name="cardBackgroundColor">@color/light_card</item>
    </style>

    <style name="Theme.MyCashBook" parent="Base.Theme.MyCashBook" />

    <!-- Transparent Status Bar Theme (Light Background, Dark Icons) -->
    <style name="Theme.MyCashBook.Transparent" parent="Theme.MyCashBook">
        <!-- Inherits transparent status bar from parent -->
    </style>
    <!-- Login Theme (Dark Background, White Icons) -->
    <style name="Theme.MyCashBook.Login" parent="Theme.MyCashBook">
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Dialog Theme -->
    <style name="Theme.MyCashBook.Dialog" parent="Theme.Material3.Light.Dialog">
        <item name="colorPrimary">@color/light_accent</item>
        <item name="colorAccent">@color/light_accent</item>
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>

    <!-- Button Styles -->
    <style name="Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/light_accent</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>

    <style name="Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/light_accent</item>
        <item name="android:textColor">@color/light_accent</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeWidth">2dp</item>
        <item name="rippleColor">@color/ripple_primary</item>
    </style>

    <!-- Card Styles -->
    <style name="Card.Book" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">0dp</item>
        <item name="cardBackgroundColor">@color/light_card</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/light_card_stroke</item>
    </style>

    <style name="Card.Dialog" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">12dp</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardBackgroundColor">@color/light_card</item>
    </style>

    <!-- Text Styles -->
    <style name="Text.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/light_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="Text.Subtitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/light_text_secondary</item>
        <item name="fontFamily">sans-serif</item>
    </style>

    <style name="Text.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/light_text_primary</item>
    </style>

    <!-- TextInputLayout Style -->
    <style name="TextInputLayout.Custom" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/light_accent</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="hintTextColor">@color/light_accent</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.MyCashBook.Splash" parent="Theme.MyCashBook">
        <item name="android:windowBackground">@color/light_accent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <!-- Inherits transparent status bar from parent -->
    </style>

    <!-- Collapsing Toolbar Text Styles -->
    <style name="TextAppearance.App.CollapsingToolbar.Expanded" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.CollapsingToolbar.Collapsed" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- FAB Perfect Circle Shape -->
    <style name="ShapeAppearance.FAB.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>