<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Solid Background - Very Deep Dark -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#030810" />
        </shape>
    </item>

    <!-- Subtle radial gradient glow from top-center -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="50%"
                android:centerY="20%"
                android:gradientRadius="500dp"
                android:startColor="#0A0D1A28"
                android:endColor="#00030810"
                android:type="radial" />
        </shape>
    </item>

    <!-- Top-left subtle accent glow -->
    <item android:top="-80dp" android:left="-80dp">
        <shape android:shape="oval">
            <size android:width="250dp" android:height="250dp" />
            <gradient
                android:centerX="50%"
                android:centerY="50%"
                android:gradientRadius="125dp"
                android:startColor="#080A1525"
                android:endColor="#00030810"
                android:type="radial" />
        </shape>
    </item>

    <!-- Bottom-right cyan accent glow (subtle) -->
    <item android:bottom="-40dp" android:right="-40dp">
        <shape android:shape="oval">
            <size android:width="180dp" android:height="180dp" />
            <gradient
                android:centerX="50%"
                android:centerY="50%"
                android:gradientRadius="90dp"
                android:startColor="#0800B4D8"
                android:endColor="#00030810"
                android:type="radial" />
        </shape>
    </item>

    <!-- Pattern overlay for texture -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#03FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
