<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_preview"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:titleTextColor="@color/white"/>

    <!-- Summary Section -->
    <TextView
        android:id="@+id/textPreviewCount"
        android:text="Items: 0"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/textPreviewDebit"
        android:text="Debit: ₹0"
        android:layout_marginTop="8dp"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/textPreviewCredit"
        android:text="Credit: ₹0"
        android:layout_marginTop="4dp"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/textPreviewBalance"
        android:text="Balance: ₹0"
        android:layout_marginTop="6dp"
        android:textStyle="bold"
        android:textSize="18sp"/>

    <!-- Preview List -->
    <ListView
        android:id="@+id/listReportPreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

</LinearLayout>
