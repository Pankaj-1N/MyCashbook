<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#162238"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Current Badge -->
        <TextView
            android:id="@+id/textCurrentBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current"
            android:textColor="#00B4D8"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/badge_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginBottom="12dp"/>

        <!-- Total Balance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_wallet"
                app:tint="#00B4D8"
                android:layout_marginEnd="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Balance"
                    android:textColor="#6B7A8F"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:id="@+id/textTotalBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹50,000"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Cash IN/OUT Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Cash IN -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/cash_in_background"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cash IN"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:id="@+id/textCashIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹70,000"
                    android:textColor="#4CAF50"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <View
                android:layout_width="12dp"
                android:layout_height="0dp"/>

            <!-- Cash OUT -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/cash_out_background"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cash OUT"
                    android:textColor="#F44336"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:id="@+id/textCashOut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹20,000"
                    android:textColor="#F44336"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:progressTint="#4CAF50"
            android:progressBackgroundTint="#F44336"
            android:progress="22"
            android:layout_marginBottom="8dp"/>

        <!-- Progress Text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textProgressPercent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="22.74%"
                android:textColor="#4CAF50"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/textComparison"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oct 22%"
                android:textColor="#6B7A8F"
                android:textSize="13sp"
                android:fontFamily="sans-serif"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
