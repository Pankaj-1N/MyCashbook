<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/transactionCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_transaction_card_income"
    android:clipToOutline="true"
    android:padding="16dp">

    <!-- Icon Container (Trending Up/Down) -->
    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_icon_green"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_trending_up"
            app:tint="#00D09C" />
    </FrameLayout>

    <!-- Header: Amount and Delete -->
    <TextView
        android:id="@+id/textAmount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:fontFamily="sans-serif-black"
        android:text="+ ₹5,000"
        android:textColor="#00D09C"
        android:textSize="18sp"
        app:layout_constraintEnd_toStartOf="@+id/btnDeleteTransaction"
        app:layout_constraintStart_toEndOf="@id/iconContainer"
        app:layout_constraintTop_toTopOf="@id/iconContainer" />

    <ImageView
        android:id="@+id/btnDeleteTransaction"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="4dp"
        android:src="@drawable/ic_delete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/textAmount"
        app:tint="?attr/colorOnSurfaceVariant" />

    <!-- Content Vertical Stack -->
    <LinearLayout
        android:id="@+id/contentStack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/textAmount"
        app:layout_constraintTop_toBottomOf="@id/textAmount">

        <!-- Description / Note -->
        <TextView
            android:id="@+id/textDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:text="Grocery shopping and dinner"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp" />

        <!-- Contact Info -->
        <TextView
            android:id="@+id/textContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif"
            android:text="Pankaj Sharma"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            android:visibility="visible" />

        <!-- Payment Info -->
        <TextView
            android:id="@+id/textPayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif"
            android:text="Google Pay"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            android:visibility="visible" />

        <!-- Footer: Date & Time -->
        <TextView
            android:id="@+id/textDateDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif"
            android:text="25 Dec 2025 • 11:30 PM"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Hidden field for compatibility -->
    <TextView
        android:id="@+id/textCategory"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
