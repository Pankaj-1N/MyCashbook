<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/subBookCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/tint_card_base"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Section: Name and Balance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSubBookName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loan to Rahul"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold" />

                <TextView
                    android:id="@+id/tvTapHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tap to view transactions"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Balance Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_glassmorphic"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:orientation="vertical"
                android:gravity="end">
                
                <TextView
                    android:id="@+id/tvBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹1,000"
                    android:textColor="#00D09C"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-bold" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Balance"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:layout_marginBottom="16dp"/>

        <!-- Bottom Section: Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- IN -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/bg_icon_circle_green" 
                    android:padding="8dp"
                    android:layout_marginEnd="12dp"/>
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IN"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"/>
                    
                    <TextView
                        android:id="@+id/tvTotalIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹3,000"
                        android:textColor="#00D09C"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </LinearLayout>

            <!-- OUT -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/bg_icon_circle_red"
                    android:padding="8dp"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OUT"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvTotalOut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹2,000"
                        android:textColor="#FF5252"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
        
        <!-- Action Buttons (Hidden but accessible via long press or swipe if needed, or kept simple as per design) -->
        <LinearLayout
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:orientation="horizontal"
             android:gravity="end"
             android:layout_marginTop="8dp"
             android:visibility="gone">
             
             <ImageButton
                 android:id="@+id/btnEditSubBook"
                 android:layout_width="40dp"
                 android:layout_height="40dp"
                 android:src="@drawable/ic_edit"
                 android:background="?attr/selectableItemBackgroundBorderless"
                 app:tint="#8C9EFF"/>

             <ImageButton
                 android:id="@+id/btnDeleteSubBook"
                 android:layout_width="40dp"
                 android:layout_height="40dp"
                 android:src="@drawable/ic_delete"
                 android:background="?attr/selectableItemBackgroundBorderless"
                 app:tint="#FF5252"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>