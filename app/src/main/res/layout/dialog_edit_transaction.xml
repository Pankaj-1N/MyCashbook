<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="?attr/cardBackgroundColor"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">
            
            <!-- Close Button + Title Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/textTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit Transaction"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_centerInParent="true"/>

                <ImageButton
                    android:id="@+id/btnClose"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    app:tint="?attr/colorOnSurface"
                    android:padding="8dp"/>
            </RelativeLayout>

            <!-- Type Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/btnTypeIn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Cash IN"
                    android:paddingVertical="12dp"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_toggle_active_green"
                    android:layout_marginEnd="8dp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/btnTypeOut"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Cash OUT"
                    android:paddingVertical="12dp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:background="@drawable/bg_toggle_unselected"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- Amount -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amount *"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/editAmount"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:hint="₹ 0.00"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:paddingHorizontal="16dp"
                android:inputType="numberDecimal"
                android:textSize="18sp"
                android:layout_marginBottom="16dp"/>

            <!-- Date & Time Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date *"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/textDate"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input_field"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:text="17-12-2025"
                        android:textColor="?attr/colorOnSurface"
                        android:drawableStart="@drawable/ic_calendar"
                        android:drawablePadding="12dp"
                        app:drawableTint="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time *"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/textTime"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input_field"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:text="23:47"
                        android:textColor="?attr/colorOnSurface"
                        android:drawableStart="@drawable/ic_clock"
                        android:drawablePadding="12dp"
                        app:drawableTint="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Contact -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact (Optional)"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/editContact"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input_field"
                android:hint="Person or company name"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:paddingHorizontal="16dp"
                android:inputType="textPersonName"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Payment Method -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Method (Optional)"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/textPaymentMethod"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input_field"
                android:text="Select Payment Method"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:drawableEnd="@drawable/ic_chevron_right"
                android:drawableTint="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="8dp"/>
                
            <!-- App Detail Input (Hidden by default) -->
            <EditText
                android:id="@+id/editPaymentDetails"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input_field"
                android:hint="Type (e.g., GPay, Bank Name)"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:paddingHorizontal="16dp"
                android:inputType="text"
                android:textSize="14sp"
                android:visibility="visible"
                android:layout_marginBottom="16dp"/>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description (Optional)"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/editDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_input_field"
                android:hint="Add transaction details..."
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:padding="16dp"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <!-- Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancel"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="16sp"
                    android:padding="12dp"
                    android:layout_marginEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Update"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#00D09C"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.cardview.widget.CardView>