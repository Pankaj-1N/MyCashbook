<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base Application Theme (DARK) -->
    <style name="Base.Theme.MyCashBook" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/cyan</item>
        <item name="colorPrimaryDark">@color/accent_dark</item>
        <item name="colorAccent">@color/cyan</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Background Colors -->
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorSurfaceVariant">@color/dark_card</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/dark_text_secondary</item>
        
        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="android:textColorSecondary">@color/dark_text_secondary</item>
        <item name="android:textColorHint">@color/dark_text_hint</item>
        
        <!-- Status Bar (Transparent - Let System Handle) -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        
        <!-- Card Colors -->
        <item name="cardBackgroundColor">@color/dark_card</item>
    </style>

    <style name="Theme.MyCashBook" parent="Base.Theme.MyCashBook" />

    <!-- NoActionBar variant -->
    <style name="Theme.MyCashBook.NoActionBar" parent="Theme.MyCashBook">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Card Style Dark -->
    <style name="Card.Book" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">0dp</item>
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/dark_card_stroke</item>
    </style>

    <!-- Text Styles Dark -->
    <style name="Text.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/dark_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Subtitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/dark_text_secondary</item>
    </style>

    <!-- Dialog Theme Dark -->
    <style name="Theme.MyCashBook.Dialog" parent="Theme.Material3.Dark.Dialog">
        <item name="colorPrimary">@color/cyan</item>
        <item name="colorAccent">@color/cyan</item>
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>

    <!-- Splash Theme Dark -->
    <style name="Theme.MyCashBook.Splash" parent="Theme.MyCashBook">
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <!-- Inherits transparent status bar from parent -->
    </style>
</resources>
